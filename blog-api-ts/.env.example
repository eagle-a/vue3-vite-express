# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=production
PORT=4000

# ==========================================
# Database
# ==========================================
MONGODB_URI=mongodb://localhost:27017/blog
MONGODB_USER=
MONGODB_PASSWORD=

# ==========================================
# JWT & Session Security
# Generate strong secrets using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 至少需要32字符，建议64字符
# ==========================================
JWT_SECRET=your_jwt_secret_here_generate_64_char_hex_min_32_chars
JWT_SECRET_CLIENT=your_jwt_secret_client_here_generate_64_char_hex
JWT_SECRET_SERVER=your_jwt_secret_server_here_generate_64_char_hex

# ==========================================
# CORS Configuration
# Comma-separated list of allowed origins
# Example: https://yourdomain.com,https://www.yourdomain.com,http://localhost:3000
# ==========================================
CORS_ORIGINS=https://yourdomain.com

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Third-party API Keys (Optional)
# ==========================================
# DeepSeek AI
DS_API_KEY=
DS_TARGET_API_URL=

# WeChat Mini Program
WECHAT_API_ID=
WECHAT_SECRET=

# Baidu AI
BAIDU_AI_APP_ID=
BAIDU_AI_API_KEY=
BAIDU_AI_SECRET_KEY=

# ==========================================
# Admin Credentials
# Generate password hash using bcrypt:
# node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
# ==========================================
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=$2a$10$...

# ==========================================
# Email Configuration (Optional)
# For password reset functionality
# ==========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ==========================================
# File Upload (Optional)
# ==========================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
